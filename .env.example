# GoHighLevel
GHL_LOCATION_ID=your_location_id
GHL_API_KEY=your_api_key
GHL_BASE_URL=https://rest.gohighlevel.com/v1

# Webhook trigger IDs (per assessment)
WEBHOOK_CULTURE_CALENDAR=your_trigger_id
WEBHOOK_CULTURE_MATURITY_AUDIT=your_trigger_id
WEBHOOK_FOUNDER_EXPOSURE_INDEX=your_trigger_id
WEBHOOK_FOUNDER_BOTTLENECK_ELIMINATOR=your_trigger_id
WEBHOOK_COMPLIANCE_SPINE=your_trigger_id
WEBHOOK_COMPLIANCE_SPINE_RISK_MAP=your_trigger_id
WEBHOOK_LEVERAGE_ENGINE=your_trigger_id
WEBHOOK_SYSTEM_ARCHITECTURE_AUDIT=your_trigger_id
WEBHOOK_EVENTS=your_trigger_id
WEBHOOK_MASTERMIND_WAITLIST=your_trigger_id
WEBHOOK_INDEX=your_trigger_id

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=your_upstash_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# CORS (optional — defaults to https://paradigmconsulting.io)
# ALLOWED_ORIGIN=https://paradigmconsulting.io
